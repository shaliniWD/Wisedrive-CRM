# Test Environment Configuration
# For QA and Integration Testing

ENVIRONMENT=test

# API Configuration
API_VERSION=v1
API_TITLE=Wisedrive Platform API (TEST)
API_PREFIX=/api
DEBUG=false

# Security
SECRET_KEY=${TEST_JWT_SECRET}
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (Isolated test cluster)
MONGO_URL=${TEST_MONGO_URL}
DB_NAME=wisedrive_test

# CORS (Restricted to test domains)
CORS_ORIGINS=https://test.wisedrive.com,https://crm-test.wisedrive.com

# CDN
CDN_BUCKET=wisedrive-test-assets
CDN_BASE_URL=https://test-assets.wisedrive.com

# External Services (Test/Sandbox mode)
RAZORPAY_KEY_ID=${TEST_RAZORPAY_KEY_ID}
RAZORPAY_KEY_SECRET=${TEST_RAZORPAY_KEY_SECRET}
RAZORPAY_WEBHOOK_SECRET=${TEST_RAZORPAY_WEBHOOK_SECRET}

INVINCIBLE_OCEAN_API_KEY=${TEST_INVINCIBLE_OCEAN_KEY}
INVINCIBLE_OCEAN_BASE_URL=https://sandbox.invincibleocean.com

# Rate Limiting (Moderate)
RATE_LIMIT_STANDARD=200
RATE_LIMIT_BULK=20
RATE_LIMIT_UPLOAD=50

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
