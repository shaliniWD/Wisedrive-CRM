# Development Environment Configuration
# DO NOT USE IN PRODUCTION

ENVIRONMENT=dev

# API Configuration
API_VERSION=v1
API_TITLE=Wisedrive Platform API (DEV)
API_PREFIX=/api
DEBUG=true

# Security (Use weak secrets only in DEV)
SECRET_KEY=${DEV_JWT_SECRET}
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
MONGO_URL=${DEV_MONGO_URL}
DB_NAME=wisedrive_dev

# CORS (Allow all in DEV)
CORS_ORIGINS=*

# CDN
CDN_BUCKET=wisedrive-dev-assets
CDN_BASE_URL=https://dev-assets.wisedrive.com

# External Services (Test/Sandbox mode)
RAZORPAY_KEY_ID=${DEV_RAZORPAY_KEY_ID}
RAZORPAY_KEY_SECRET=${DEV_RAZORPAY_KEY_SECRET}
RAZORPAY_WEBHOOK_SECRET=${DEV_RAZORPAY_WEBHOOK_SECRET}

INVINCIBLE_OCEAN_API_KEY=${DEV_INVINCIBLE_OCEAN_KEY}
INVINCIBLE_OCEAN_BASE_URL=https://sandbox.invincibleocean.com

# Rate Limiting (Relaxed for DEV)
RATE_LIMIT_STANDARD=1000
RATE_LIMIT_BULK=100
RATE_LIMIT_UPLOAD=100

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
