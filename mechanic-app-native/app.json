{
  "expo": {
    "name": "WiseDrive Mechanic",
    "slug": "wisedrive-mechanic",
    "version": "1.8.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "wisedrive-mechanic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3D7B3D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cleansecar.wisedrive.mechanic",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "This app uses Bluetooth to connect to OBD-II scanners for vehicle diagnostics.",
        "NSBluetoothPeripheralUsageDescription": "This app uses Bluetooth to connect to OBD-II scanners for vehicle diagnostics.",
        "UIBackgroundModes": [
          "bluetooth-central",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "allowBackup": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3D7B3D",
        "monochromeImage": "./assets/adaptive-icon.png"
      },
      "package": "com.cleansecar.wisedrive.mechanic",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "Allow $(PRODUCT_NAME) to connect to OBD-II scanners"
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "kalyandhar",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "28feef43-bde0-4bb1-9fcd-9e17d6dadc3c"
      }
    }
  }
}
